# Variáveis de ambiente do front-end (Vite expõe só as que começam com VITE_).
# Copie para .env e preencha. NÃO comite o .env real.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Apenas para scripts locais de manutenção (scripts/*.mjs) ---
# NUNCA coloque a service_role em variável VITE_ nem comite este valor.
# SUPABASE_SERVICE_ROLE_KEY=
